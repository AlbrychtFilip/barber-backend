            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BarberKing\",\n  \"address\": \"ul. Mokotowska 5, Warszawa\",\n  \"phoneNumber\": \"+48123456789\"\n}"
            }
          }
        },
        {
          "name": "Get All Barbershops",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/barbershops"
          }
        },
        {
          "name": "Get Barbershop by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/barbershops/:id",
            "variable": [
              { "key": "id", "value": "" }
            ]
          }
        },
        {
          "name": "Update Barbershop",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/barbershops/:id",
            "variable": [
              { "key": "id", "value": "" }
            ],
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BarberKing Premium\",\n  \"address\": \"ul. Nowy Swiat 10, Warszawa\",\n  \"phoneNumber\": \"+48987654321\"\n}"
            }
          }
        },
        {
          "name": "Delete Barbershop",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/barbershops/:id",
            "variable": [
              { "key": "id", "value": "" }
            ]
          }
        }
      ]
    },
