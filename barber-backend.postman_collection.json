            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientName\": \"Adam Nowak\",\n  \"clientEmail\": \"adam@example.com\",\n  \"clientPhoneNumber\": \"+48999888777\",\n  \"startTime\": \"2026-06-21T10:00:00Z\",\n  \"duration\": 30,\n  \"employeeId\": \"\",\n  \"workstationId\": \"\"\n}"
